generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  TEACHER
  STUDENT
}

enum AttendanceStatus {
  attended
  absent
  late
  no_show
}

enum ClassStatus {
  SCHEDULED
  RESERVED
  COMPLETED
  CANCELED
}

enum ClassType {
  ONE_ON_ONE
  GROUP
}

enum AvailabilityExceptionType {
  UNAVAILABLE
  AVAILABLE
}

enum ClassEnrollmentStatus {
  CONFIRMED
  CANCELLED
}

enum NotificationStatus {
  PENDING
  SENT
  RETRY
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phoneE164 String?
  role      UserRole @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherProfile        Teacher?
  studentProfile        Student?
  attendanceMarks       AttendanceRecord[]
  instructorAttendances InstructorAttendance[]
  cancellations         Cancellation[]
  auditLogs             AuditLog[]
  bookedClasses         ClassEvent[]               @relation("ClassBookedBy")
  assignmentActions     StudentTeacherAssignment[] @relation("AssignmentCreatedBy")
}

model Teacher {
  id       String @id @default(cuid())
  userId   String @unique
  timezone String @default("America/Bogota")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  classEvents             ClassEvent[]
  studentAssignments      StudentTeacherAssignment[]
  availabilityBlocks      TeacherAvailabilityBlock[]
  availabilityExceptions  TeacherAvailabilityException[]
}

model Student {
  id          String  @id @default(cuid())
  userId      String  @unique
  studentCode String  @unique
  notes       String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  packages    HourPackage[]
  enrollments ClassEnrollment[]
  attendances AttendanceRecord[]
  teacherAssignments StudentTeacherAssignment[]
}

model StudentTeacherAssignment {
  id               String   @id @default(cuid())
  studentId        String
  teacherId        String
  assignedByUserId String
  isPrimary        Boolean  @default(true)
  startsAt         DateTime @default(now())
  endsAt           DateTime?
  notes            String?
  createdAt        DateTime @default(now())

  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher    Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  assignedBy User    @relation("AssignmentCreatedBy", fields: [assignedByUserId], references: [id], onDelete: Restrict)

  @@index([teacherId, startsAt])
  @@index([studentId, isPrimary])
}

model HourPackage {
  id         String   @id @default(cuid())
  studentId  String
  totalHours Int
  usedHours  Int      @default(0)
  reservedHours Int   @default(0)
  totalMinutes Int    @default(1200)
  usedMinutes  Int    @default(0)
  reservedMinutes Int @default(0)
  validFrom  DateTime
  validTo    DateTime
  status     String   @default("ACTIVE")
  allowedClassTypes String @default("ONE_ON_ONE,GROUP")
  allowedDurations  String @default("50,60,90")

  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollments ClassEnrollment[]
}

model ClassEvent {
  id            String      @id @default(cuid())
  googleEventId String?     @unique
  title         String
  startAt       DateTime
  endAt         DateTime
  timezone      String      @default("America/Bogota")
  meetUrl       String?
  status        ClassStatus @default(SCHEDULED)
  classType     ClassType   @default(ONE_ON_ONE)
  durationMinutes Int       @default(60)
  capacity      Int         @default(1)
  teacherId     String
  bookedById    String?
  bookingSource String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  teacher              Teacher               @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments          ClassEnrollment[]
  instructorAttendance InstructorAttendance?
  attendanceRecords    AttendanceRecord[]
  cancellations        Cancellation[]
  bookedBy             User?                 @relation("ClassBookedBy", fields: [bookedById], references: [id], onDelete: SetNull)

  @@index([teacherId, startAt, endAt])
  @@index([status, startAt])
}

model ClassEnrollment {
  id           String                @id @default(cuid())
  classEventId String
  studentId    String
  packageId    String
  status       ClassEnrollmentStatus @default(CONFIRMED)
  reservedHours Int                  @default(0)
  consumedHours Int                  @default(0)
  reservedMinutes Int                @default(0)
  consumedMinutes Int                @default(0)

  classEvent ClassEvent        @relation(fields: [classEventId], references: [id], onDelete: Cascade)
  student    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  package    HourPackage       @relation(fields: [packageId], references: [id], onDelete: Restrict)
  attendance AttendanceRecord?

  @@unique([classEventId, studentId])
}

model AttendanceRecord {
  id           String           @id @default(cuid())
  classEventId String
  studentId    String
  status       AttendanceStatus
  markedBy     String
  markedAt     DateTime         @default(now())

  classEvent ClassEvent      @relation(fields: [classEventId], references: [id], onDelete: Cascade)
  student    Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  marker     User            @relation(fields: [markedBy], references: [id], onDelete: Cascade)
  enrollment ClassEnrollment @relation(fields: [classEventId, studentId], references: [classEventId, studentId], onDelete: Cascade)

  @@unique([classEventId, studentId])
}

model InstructorAttendance {
  id           String   @id @default(cuid())
  classEventId String   @unique
  instructorId String
  present      Boolean  @default(false)
  markedAt     DateTime @default(now())

  classEvent ClassEvent @relation(fields: [classEventId], references: [id], onDelete: Cascade)
  instructor User       @relation(fields: [instructorId], references: [id], onDelete: Cascade)
}

model Cancellation {
  id           String   @id @default(cuid())
  classEventId String
  requestedBy  String
  requestTime  DateTime @default(now())
  reason       String
  wasAllowed   Boolean
  graceHours   Int

  classEvent ClassEvent @relation(fields: [classEventId], references: [id], onDelete: Cascade)
  requester  User       @relation(fields: [requestedBy], references: [id], onDelete: Cascade)
}

model TeacherAvailabilityBlock {
  id              String    @id @default(cuid())
  teacherId       String
  weekday         Int
  startLocalTime  String
  endLocalTime    String
  timezone        String    @default("America/Bogota")
  durationMinutes Int       @default(60)
  classType       ClassType @default(ONE_ON_ONE)
  capacity        Int       @default(1)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, weekday, isActive])
}

model TeacherAvailabilityException {
  id        String                    @id @default(cuid())
  teacherId String
  startsAt  DateTime
  endsAt    DateTime
  type      AvailabilityExceptionType @default(UNAVAILABLE)
  reason    String?
  createdAt DateTime                  @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, startsAt, endsAt])
}

model BookingRule {
  id                     String   @id @default(cuid())
  minimumNoticeHours     Int      @default(6)
  maximumNoticeDays      Int      @default(30)
  defaultDurationMinutes Int      @default(60)
  bufferMinutes          Int      @default(15)
  allowStudentReschedule Boolean  @default(true)
  allowTeacherReschedule Boolean  @default(true)
  allowStaffOverride     Boolean  @default(true)
  firstBookingStaffAssisted Boolean @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model NotificationAttempt {
  id         String             @id @default(cuid())
  targetType String
  targetId   String
  channel    String
  status     NotificationStatus @default(PENDING)
  providerId String?
  payload    String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model CalendarSyncEvent {
  id       String   @id @default(cuid())
  source   String
  eventId  String
  status   String
  payload  String
  syncedAt DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  before     String?
  after      String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)
}
