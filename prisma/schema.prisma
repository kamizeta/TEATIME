generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  TEACHER
  STUDENT
}

enum AccessTokenPurpose {
  INVITATION
  RESET
}

enum AttendanceStatus {
  attended
  absent
  late
  no_show
}

enum ClassStatus {
  SCHEDULED
  RESERVED
  COMPLETED
  CANCELED
}

enum ClassType {
  ONE_ON_ONE
  GROUP
}

enum AvailabilityExceptionType {
  UNAVAILABLE
  AVAILABLE
}

enum ClassEnrollmentStatus {
  CONFIRMED
  CANCELLED
}

enum NotificationStatus {
  PENDING
  SENT
  RETRY
  FAILED
}

enum ContactStatus {
  NEW
  CONTACTED
  TRIAL_SCHEDULED
  ACTIVE_STUDENT
  LOST
}

enum ContactSource {
  WHATSAPP
  WEBSITE
  REFERRAL
  MANUAL
  OTHER
}

enum CrmActivityType {
  NOTE
  WHATSAPP
  CALL
  EMAIL
  FOLLOW_UP
  TRIAL_CLASS
}

enum CrmActivityStatus {
  OPEN
  DONE
  CANCELED
}

enum IncidentType {
  MISSING_ATTENDANCE
  LATE_CANCELLATION
  PACKAGE_MISMATCH
  CALENDAR_CONFLICT
  TEACHER_ABSENT
  STUDENT_CLAIM
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum WeeklyClosingStatus {
  DRAFT
  REVIEWED
}

enum MessageTemplateChannel {
  WHATSAPP
  EMAIL
  IN_APP
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phoneE164 String?
  role      UserRole @default(STUDENT)
  isActive  Boolean  @default(true)
  emailVerifiedAt      DateTime?
  forcePasswordChange  Boolean   @default(false)
  passwordExpiresAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherProfile        Teacher?
  studentProfile        Student?
  attendanceMarks       AttendanceRecord[]
  instructorAttendances InstructorAttendance[]
  cancellations         Cancellation[]
  auditLogs             AuditLog[]
  bookedClasses         ClassEvent[]               @relation("ClassBookedBy")
  assignmentActions     StudentTeacherAssignment[] @relation("AssignmentCreatedBy")
  ownedCrmContacts      CrmContact[]               @relation("CrmContactOwner")
  crmActivities         CrmActivity[]
  reportedIncidents     Incident[]                 @relation("IncidentReporter")
  assignedIncidents     Incident[]                 @relation("IncidentAssignee")
  resolvedIncidents     Incident[]                 @relation("IncidentResolver")
  weeklyClosings        WeeklyClosing[]            @relation("WeeklyClosingReviewedBy")
  staffPermission       StaffPermission?
  messageTemplates      MessageTemplate[]          @relation("MessageTemplateUpdatedBy")
  accessTokens          AccessToken[]
}

model AccessToken {
  id          String             @id @default(cuid())
  userId      String
  tokenHash   String             @unique
  purpose     AccessTokenPurpose
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String?
  createdAt   DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
}

model Teacher {
  id       String @id @default(cuid())
  userId   String @unique
  timezone String @default("America/Bogota")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  classEvents             ClassEvent[]
  studentAssignments      StudentTeacherAssignment[]
  availabilityBlocks      TeacherAvailabilityBlock[]
  availabilityExceptions  TeacherAvailabilityException[]
}

model Student {
  id          String  @id @default(cuid())
  userId      String  @unique
  studentCode String  @unique
  notes       String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  packages    HourPackage[]
  enrollments ClassEnrollment[]
  attendances AttendanceRecord[]
  teacherAssignments StudentTeacherAssignment[]
  crmContacts        CrmContact[]
}

model CrmContact {
  id                String        @id @default(cuid())
  fullName          String
  email             String?
  phoneE164         String?
  preferredLanguage String        @default("es")
  source            ContactSource @default(MANUAL)
  status            ContactStatus @default(NEW)
  interestProgram   String?
  level             String?
  nextFollowUpAt    DateTime?
  notes             String?
  ownerId           String?
  convertedStudentId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  owner            User?    @relation("CrmContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  convertedStudent Student? @relation(fields: [convertedStudentId], references: [id], onDelete: SetNull)
  activities       CrmActivity[]

  @@index([status, createdAt])
  @@index([nextFollowUpAt])
  @@index([ownerId])
}

model CrmActivity {
  id          String            @id @default(cuid())
  contactId   String
  actorId     String
  type        CrmActivityType   @default(NOTE)
  status      CrmActivityStatus @default(OPEN)
  title       String
  body        String?
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  contact CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  actor   User       @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
  @@index([status, dueAt])
}

model StudentTeacherAssignment {
  id               String   @id @default(cuid())
  studentId        String
  teacherId        String
  assignedByUserId String
  isPrimary        Boolean  @default(true)
  startsAt         DateTime @default(now())
  endsAt           DateTime?
  notes            String?
  createdAt        DateTime @default(now())

  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher    Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  assignedBy User    @relation("AssignmentCreatedBy", fields: [assignedByUserId], references: [id], onDelete: Restrict)

  @@index([teacherId, startsAt])
  @@index([studentId, isPrimary])
}

model HourPackage {
  id         String   @id @default(cuid())
  studentId  String
  totalHours Int
  usedHours  Int      @default(0)
  reservedHours Int   @default(0)
  totalMinutes Int    @default(1200)
  usedMinutes  Int    @default(0)
  reservedMinutes Int @default(0)
  validFrom  DateTime
  validTo    DateTime
  status     String   @default("ACTIVE")
  allowedClassTypes String @default("ONE_ON_ONE,GROUP")
  allowedDurations  String @default("50,60,90")
  classLanguage     String @default("Inglés")

  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollments ClassEnrollment[]
}

model ClassEvent {
  id            String      @id @default(cuid())
  googleEventId String?     @unique
  title         String
  startAt       DateTime
  endAt         DateTime
  timezone      String      @default("America/Bogota")
  meetUrl       String?
  status        ClassStatus @default(SCHEDULED)
  classType     ClassType   @default(ONE_ON_ONE)
  durationMinutes Int       @default(60)
  capacity      Int         @default(1)
  teacherId     String
  bookedById    String?
  bookingSource String?
  classLanguage String      @default("Inglés")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  teacher              Teacher               @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments          ClassEnrollment[]
  instructorAttendance InstructorAttendance?
  attendanceRecords    AttendanceRecord[]
  cancellations        Cancellation[]
  bookedBy             User?                 @relation("ClassBookedBy", fields: [bookedById], references: [id], onDelete: SetNull)
  incidents            Incident[]

  @@index([teacherId, startAt, endAt])
  @@index([status, startAt])
}

model Incident {
  id             String           @id @default(cuid())
  title          String
  description    String?
  type           IncidentType     @default(OTHER)
  severity       IncidentSeverity @default(MEDIUM)
  status         IncidentStatus   @default(OPEN)
  classEventId   String?
  reportedById   String
  assignedToId   String?
  resolvedById   String?
  resolutionNote String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  resolvedAt     DateTime?

  classEvent ClassEvent? @relation(fields: [classEventId], references: [id], onDelete: SetNull)
  reportedBy User        @relation("IncidentReporter", fields: [reportedById], references: [id], onDelete: Restrict)
  assignedTo User?       @relation("IncidentAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  resolvedBy User?       @relation("IncidentResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, severity, createdAt])
  @@index([assignedToId, status])
  @@index([classEventId])
}

model WeeklyClosing {
  id           String              @id @default(cuid())
  weekStart    DateTime
  weekEnd      DateTime
  status       WeeklyClosingStatus @default(DRAFT)
  summary      String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  reviewedBy User? @relation("WeeklyClosingReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([weekStart])
  @@index([status, weekStart])
}

model MessageTemplate {
  id              String                 @id @default(cuid())
  key             String                 @unique
  name            String
  channel         MessageTemplateChannel @default(WHATSAPP)
  language        String                 @default("es")
  subject         String?
  body            String
  isActive        Boolean                @default(true)
  updatedByUserId String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  updatedBy User? @relation("MessageTemplateUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([channel, language, isActive])
}

model StaffPermission {
  id             String   @id @default(cuid())
  userId         String   @unique
  canManageUsers Boolean  @default(false)
  canManageRules Boolean  @default(false)
  canCloseWeeks  Boolean  @default(true)
  canResolveIncidents Boolean @default(true)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClassEnrollment {
  id           String                @id @default(cuid())
  classEventId String
  studentId    String
  packageId    String
  status       ClassEnrollmentStatus @default(CONFIRMED)
  reservedHours Int                  @default(0)
  consumedHours Int                  @default(0)
  reservedMinutes Int                @default(0)
  consumedMinutes Int                @default(0)

  classEvent ClassEvent        @relation(fields: [classEventId], references: [id], onDelete: Cascade)
  student    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  package    HourPackage       @relation(fields: [packageId], references: [id], onDelete: Restrict)
  attendance AttendanceRecord?

  @@unique([classEventId, studentId])
}

model AttendanceRecord {
  id           String           @id @default(cuid())
  classEventId String
  studentId    String
  status       AttendanceStatus
  markedBy     String
  markedAt     DateTime         @default(now())

  classEvent ClassEvent      @relation(fields: [classEventId], references: [id], onDelete: Cascade)
  student    Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  marker     User            @relation(fields: [markedBy], references: [id], onDelete: Cascade)
  enrollment ClassEnrollment @relation(fields: [classEventId, studentId], references: [classEventId, studentId], onDelete: Cascade)

  @@unique([classEventId, studentId])
}

model InstructorAttendance {
  id           String   @id @default(cuid())
  classEventId String   @unique
  instructorId String
  present      Boolean  @default(false)
  markedAt     DateTime @default(now())

  classEvent ClassEvent @relation(fields: [classEventId], references: [id], onDelete: Cascade)
  instructor User       @relation(fields: [instructorId], references: [id], onDelete: Cascade)
}

model Cancellation {
  id           String   @id @default(cuid())
  classEventId String
  requestedBy  String
  requestTime  DateTime @default(now())
  reason       String
  wasAllowed   Boolean
  graceHours   Int

  classEvent ClassEvent @relation(fields: [classEventId], references: [id], onDelete: Cascade)
  requester  User       @relation(fields: [requestedBy], references: [id], onDelete: Cascade)
}

model TeacherAvailabilityBlock {
  id              String    @id @default(cuid())
  teacherId       String
  weekday         Int
  startLocalTime  String
  endLocalTime    String
  timezone        String    @default("America/Bogota")
  durationMinutes Int       @default(60)
  classType       ClassType @default(ONE_ON_ONE)
  capacity        Int       @default(1)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, weekday, isActive])
}

model TeacherAvailabilityException {
  id        String                    @id @default(cuid())
  teacherId String
  startsAt  DateTime
  endsAt    DateTime
  type      AvailabilityExceptionType @default(UNAVAILABLE)
  reason    String?
  createdAt DateTime                  @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, startsAt, endsAt])
}

model BookingRule {
  id                     String   @id @default(cuid())
  minimumNoticeHours     Int      @default(6)
  maximumNoticeDays      Int      @default(30)
  defaultDurationMinutes Int      @default(60)
  bufferMinutes          Int      @default(15)
  allowStudentReschedule Boolean  @default(true)
  allowTeacherReschedule Boolean  @default(true)
  allowStaffOverride     Boolean  @default(true)
  firstBookingStaffAssisted Boolean @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model NotificationAttempt {
  id         String             @id @default(cuid())
  targetType String
  targetId   String
  channel    String
  status     NotificationStatus @default(PENDING)
  providerId String?
  payload    String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model CalendarSyncEvent {
  id       String   @id @default(cuid())
  source   String
  eventId  String
  status   String
  payload  String
  syncedAt DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipHash    String?
  userAgent String?
  success   Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipHash, createdAt])
  @@index([success, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  before     String?
  after      String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)
}
